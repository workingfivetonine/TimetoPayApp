{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --no-frozen-lockfile && pnpm run build",
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "preDeploy": "find /app -name 'index.mjs' 2>/dev/null && echo 'Found above' || echo 'No index.mjs found anywhere'",
    "startCommand": "node /app/artifacts/api-server/dist/index.mjs",
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
